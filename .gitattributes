# Normalitza salts de línia: LF al repositori, conversió automàtica a checkout
* text=auto eol=lf

# Fitxers que han de ser sempre LF
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
*.sql   text eol=lf
Makefile text eol=lf

# Fitxers binaris — sense conversió
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.tif   binary
*.tiff  binary
